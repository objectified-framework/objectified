{
  "name": "objectified-data-generator",
  "version": "0.0.1",
  "description": "OpenAPI Express REST code generator for TypeScript",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "generate": "ts-node bin/gen.ts openapi/main.yml -b Example",
    "build": "npm run generate ; tsc",
    "start": "npm run build ; ts-node bin/server.ts"
  },
  "compilerOptions": {
    "esModuleInterop": true,
    "moduleResolution": "node"
  },
  "bin": {
    "tseo-gen": "./bin/gen.ts"
  },
  "author": "ksuenobu@fastmail.com",
  "license": "Apache License 2.0",
  "files": [
    "/dist"
  ],
  "dependencies": {
    "typescript": "^5.4.4",
    "yaml": "^2.4.1"
  },
  "devDependencies": {
    "@types/node": "^18.7.23"
  }
}
